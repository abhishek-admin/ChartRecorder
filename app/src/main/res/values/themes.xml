<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ChartRecorder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colours -->
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary colours -->
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorSecondaryVariant">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
